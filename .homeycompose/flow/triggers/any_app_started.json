{
  "id": "any_app_started",
  "title": {
    "en": "Application has started"
  },
  "titleFormatted": {
    "en": "[[app_name]] has started"
  },
  "hint": {
    "en": "This trigger fires when any application becomes visible on the TV."
  },
  "tokens": [
    {
      "name": "app_name",
      "type": "string",
      "title": {
        "en": "Application name"
      }
    },
    {
      "name": "app_id",
      "type": "string",
      "title": {
        "en": "Application ID"
      }
    }
  ],
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=Samsung"
    }
  ]
}
